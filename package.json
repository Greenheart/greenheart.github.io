{
    "name": "greenheart.github.io",
    "version": "3.0.0",
    "author": "Samuel Plumppu",
    "license": "AGPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Greenheart/greenheart.github.io.git"
    },
    "homepage": "https://samuelplumppu.se",
    "private": true,
    "scripts": {
        "dev": "pnpm update-skills && vite dev",
        "build": "pnpm update-skills && vite build",
        "preview": "vite preview",
        "gh-pages": "gh-pages -d build -b master -t",
        "update-skills": "node scripts/update-skills.ts",
        "encrypt:text": "node --env-file .env scripts/encrypt-text.ts",
        "lint": "prettier --check .",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@iconify-json/fluent": "^1.2.41",
        "@iconify-json/lucide": "^1.2.98",
        "@iconify-json/mdi": "^1.2.3",
        "@iconify/tailwind4": "^1.2.3",
        "@markdoc/markdoc": "^0.5.6",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/enhanced-img": "^0.10.4",
        "@sveltejs/kit": "^2.55.0",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.1",
        "@types/node": "^25.5.0",
        "@types/qrcode": "^1.5.6",
        "feed": "^5.2.0",
        "gh-pages": "^6.3.0",
        "markdoc-svelte": "^4.1.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "qrcode": "^1.5.4",
        "reading-time": "^1.5.0",
        "shiki": "^4.0.2",
        "svelte": "^5.53.12",
        "svelte-meta-tags": "^4.5.0",
        "tailwindcss": "^4.2.1",
        "tinyclip": "0.1.12",
        "title-case": "^4.3.2",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "zod": "^4.3.6"
    },
    "type": "module",
    "prettier": {
        "semi": false,
        "singleQuote": true,
        "tabWidth": 4,
        "trailingComma": "all",
        "plugins": [
            "prettier-plugin-svelte",
            "prettier-plugin-tailwindcss"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@tailwindcss/oxide",
            "esbuild",
            "sharp"
        ]
    }
}
